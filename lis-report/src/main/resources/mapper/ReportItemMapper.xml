<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lis.report.mapper.ReportItemMapper">

    <select id="selectByReportId" resultType="com.lis.report.entity.ReportItemDO">
        SELECT * FROM report_item WHERE report_id = #{reportId} ORDER BY sort ASC
    </select>

    <delete id="deleteByReportId">
        DELETE FROM report_item WHERE report_id = #{reportId}
    </delete>

</mapper>
