<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lis.user.mapper.DictTypeMapper">

    <resultMap id="DictTypeResultMap" type="com.lis.user.entity.DictTypeDO">
        <id column="id" property="id"/>
        <result column="dict_name" property="dictName"/>
        <result column="dict_type" property="dictType"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectByDictType" resultMap="DictTypeResultMap">
        SELECT * FROM sys_dict_type WHERE dict_type = #{dictType}
    </select>

    <select id="selectDictTypeList" resultMap="DictTypeResultMap">
        SELECT * FROM sys_dict_type WHERE 1=1
        <if test="dictName != null and dictName != ''">
            AND dict_name LIKE CONCAT('%', #{dictName}, '%')
        </if>
        <if test="dictType != null and dictType != ''">
            AND dict_type LIKE CONCAT('%', #{dictType}, '%')
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
